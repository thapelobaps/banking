# Next.js web application
NEXT_PUBLIC_SITE_URL=http://localhost:3000
KAPE_API_URL=http://localhost:5000

# Bank linking stays on the demo adapter unless both applications are switched.
# Use stitch only after the ASP.NET API has Stitch enabled with valid sandbox credentials.
BANK_AGGREGATION_PROVIDER=demo
STITCH_REDIRECT_URI=

# The ASP.NET Core API reads its SQL Server connection, JWT signing key and
# Stitch client secret from backend configuration or environment variables.
# Do not place backend secrets in this frontend file.
