{
  "ConnectionStrings": {
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=KapeApp;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "Kape.Api",
    "Audience": "Kape.Web"
  },
  "Providers": {
    "BankAggregation": {
      "ActiveProvider": "demo-bank-aggregator"
    },
    "Stitch": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "WebhookSecret": "",
      "AuthorizationEndpoint": "https://secure.stitch.money/connect/authorize",
      "TokenEndpoint": "https://secure.stitch.money/connect/token",
      "GraphQlEndpoint": "https://api.stitch.money/graphql",
      "RestApiBaseUrl": "https://api.stitch.money/v2",
      "UserScopes": [
        "openid",
        "offline_access",
        "accounts",
        "balances",
        "transactions",
        "accountholders"
      ],
      "ClientScopes": [
        "client_paymentrequest"
      ],
      "ClientTokenRefreshSkewSeconds": 120
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
